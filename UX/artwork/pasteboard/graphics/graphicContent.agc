y":324,"from":347,"to":384,"x":0}]]},{"lines":[[{"y":351,"from":385,"to":385,"x":0}]]},{"lines":[[{"y":378,"from":386,"to":393,"x":0}]]},{"lines":[[{"y":405,"from":394,"to":397,"x":0,"style":{"font":{"postscriptName":"AppleColorEmoji","family":"Apple Color Emoji","style":"Regular"}}},{"y":405,"from":397,"to":423}]]},{"lines":[[{"y":432,"from":424,"to":424,"x":0}]]},{"lines":[[{"y":459,"from":425,"to":476,"x":0}]]},{"lines":[[{"y":486,"from":477,"to":531,"x":0}]]},{"lines":[[{"y":513,"from":532,"to":579,"x":0}]]},{"lines":[[{"y":540,"from":580,"to":580,"x":0}]]},{"lines":[[{"y":567,"from":581,"to":586,"x":0}]]},{"lines":[[{"y":594,"from":587,"to":590,"x":0,"style":{"font":{"postscriptName":"AppleColorEmoji","family":"Apple Color Emoji","style":"Regular"}}},{"y":594,"from":590,"to":621}]]},{"lines":[[{"y":621,"from":622,"to":622,"x":0}]]},{"lines":[[{"y":648,"from":623,"to":664,"x":0}]]},{"lines":[[{"y":675,"from":665,"to":722,"x":0}]]},{"lines":[[{"y":702,"from":723,"to":771,"x":0}]]}],"rawText":"Breakdown\n1️⃣ Break Down Bloat at the Source\n\nBloating starts when food isn’t fully broken down.\nOur advanced enzyme system works fast to reduce \nfermentation and digestive pressure before it builds.\n\nCalm\n2️⃣ Calm Digestive Reactivity\n\nDigestive stress can amplify discomfort after meals.\nBioactive botanicals help soothe irritation and support \nsmoother, more comfortable digestion.\n\nRestore\n3️⃣ Restore Microbial Balance\n\nRecurring bloating often signals an imbalanced gut.\nClinically studied BC99 probiotic supports beneficial \nbacteria to help stabilize digestion over time.\n\nRenew\n4️⃣ Strengthen the Gut Environment\n\nTrue renewal happens beneath the surface.\nPolyphenol-rich pomegranate extract supports a healthier \nmicrobial environment for long-term gut balance."}},{"type":"group","name":"Group 171","meta":{"ux":{"nameL10N":"SHAPE_GROUP"}},"id":"dfac267d-a697-4ce9-a145-0b8c9b741aa1","transform":{"a":1,"b":0,"c":0,"d":1,"tx":0,"ty":-35},"group":{"chil